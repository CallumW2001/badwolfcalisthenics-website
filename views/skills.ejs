<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gallery - Badwolf Calisthenics</title>
    <link rel="stylesheet" href="css/styles.css" />
    <link rel="stylesheet" href="css/skills.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Oswald:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Firebase SDKs -->
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"></script>

    <!-- Firebase Config -->
    <script src="js/firebase-config.js"></script>

    <script src="js/app.js" defer></script>
  </head>
  <body>
    <%- include('partials/header') %>

    <main>
      <section>
        <h2>Skills</h2>
        <div class="gallery-grid">
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 1" />
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 2" />
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 3" />
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 4" />
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 5" />
          <img src="images/Room 2.jpg" alt="Calisthenics Pose 6" />
          <!-- Add more images here -->
        </div>
      </section>
    </main>

    <footer>
      <p>&copy; 2025 Badwolf Calisthenics. All rights reserved.</p>
    </footer>

    <script>
      document.querySelectorAll(".gallery-grid img").forEach((img, i) => {
        img.style.setProperty("--img-index", i);
      });
    </script>
  </body>
</html>
