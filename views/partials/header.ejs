<style>
  /* Header & nav styles used site-wide */
  header.hero {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: #000;
    border-bottom: 2px solid #1e1e1e;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo img {
    height: 50px;
    margin-right: 1rem;
  }

  .title {
    font-family: "Orbitron", sans-serif;
    font-size: 1.5rem;
    color: #00aaff;
    margin: 0;
    font-weight: bold;
    text-decoration: none;
  }

  .logo h1 {
    font-family: "Orbitron", sans-serif;
    font-size: 1.5rem;
    color: #00aaff;
    margin: 0;
  }

  nav a.active,
  nav a:hover {
    color: #00aaff;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  nav ul li {
    display: flex;
    align-items: center;
  }

  nav a {
    text-decoration: none;
    font-family: "Orbitron", sans-serif;
    color: #ccc;
    font-weight: bold;
    transition: color 0.3s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  nav a:hover {
    color: #00aaff;
  }

  nav a.button {
    background-color: #00aaff;
    color: #000;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    font-family: "Orbitron", sans-serif;
    font-weight: bold;
    cursor: pointer;
    height: auto;
  }

  nav a.button:hover {
    background-color: #008fcc;
  }

  .nav-auth a {
    visibility: hidden; /* hide all auth buttons initially */
    margin-right: 1rem;
  }

  /* Hamburger hidden on desktop */
  /* Mobile toggle icon */
  .menu-toggle {
    display: none;
    font-size: 2rem;
    font-family: "Orbitron", sans-serif;
    background: none;
    border: none;
    color: #00aaff;
    cursor: pointer;
    z-index: 2001;
  }

  /* Fullscreen navbar overlay (hidden by default) */
  .navbar-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0a0a0a60;
    z-index: 2000;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .navbar-overlay.open {
    display: flex;
  }

  .navbar-overlay ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 0;
    margin: 0;
    align-items: center;
  }

  .navbar-overlay a {
    color: #00aaff;
    font-size: 1.5rem;
    font-family: "Orbitron", sans-serif;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .navbar-overlay a:hover {
    color: #008fcc;
  }

  /* Toggle button (☰) */
  .menu-toggle {
    display: none;
    font-family: "Orbitron", sans-serif;
    font-size: 2rem;
    background: none;
    border: none;
    color: #00aaff;
    cursor: pointer;
    z-index: 2001;
  }

  /* Desktop navbar */
  .navbar-desktop {
    display: flex;
  }

  .navbar-desktop ul {
    list-style: none;
    display: flex;
    gap: 1rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  /* Mobile fullscreen overlay nav */
  .navbar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background-color: #0a0a0aec;
    z-index: 2000;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .navbar-overlay.open {
    display: flex;
  }

  .navbar-overlay ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 0;
    margin: 0;
    margin-left: auto;
    margin-right: auto;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 400px;
  }

  .navbar-overlay a {
    color: #00aaff;
    font-size: 1.5rem;
    font-family: "Orbitron", sans-serif;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .navbar-overlay a:hover {
    color: #008fcc;
  }

  .nav-auth {
    display: flex;
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .navbar-desktop {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    /* Make the mobile nav ul vertical and centered */
    .navbar-overlay nav ul {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    /* Make nav-auth container vertical, full width, and aligned */
    .navbar-overlay .nav-auth {
      display: flex;
      flex-direction: column; /* stack buttons vertically */
      align-items: center;
      justify-content: center;
      width: 100%;
      margin-top: 1.5rem;
      gap: 1rem;
    }

    /* Override visibility and margin-right for nav-auth links inside overlay */
    .navbar-overlay .nav-auth a {
      visibility: visible;
      margin-right: 0;
    }

    /* Buttons fill most of the width and center text */
    .navbar-overlay .nav-auth a.button {
      width: 80%;
      max-width: 250px;
      margin: 0 auto;
      text-align: center;
    }
  }
</style>

<link
  rel="preload"
  href="https://fonts.gstatic.com/s/orbitron/v34/yMJRMIlzdpvBhQQL_Qq7dy0.woff2"
  as="font"
  type="font/woff2"
  crossorigin="anonymous"
/>
<link
  rel="stylesheet"
  href="/css/styles.css"
  media="print"
  onload="this.media='all'"
/>
<link
  rel="stylesheet"
  href="/css/nav.css"
  media="print"
  onload="this.media='all'"
/>

<noscript>
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/nav.css" />
</noscript>

<!-- Preconnect early -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Google Fonts with font-display: swap -->
<link
  href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap"
  rel="stylesheet"
/>

<header class="hero">
  <div class="logo">
    <img
      src="images/badwolf_calisthenics_logo-removebg-preview.png"
      alt="Badwolf Calisthenics Logo"
      width="60"
      height="120"
    />
    <a href="/" class="title <%= currentPage === 'home' ? 'active' : '' %>">
      Badwolf Calisthenics
    </a>
  </div>

  <!-- Menu toggle button for small screens -->
  <button class="menu-toggle" aria-label="Toggle menu">☰</button>

  <!-- Regular nav bar (desktop) -->
  <nav class="navbar-desktop">
    <ul>
      <li id="training-plans-tab" style="display: none">
        <a
          href="your-training-plans"
          class="<%= currentPage === 'your-training-plans' ? 'active' : '' %>"
        >
          Your Training Plans
        </a>
      </li>
      <li>
        <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>"
          >Home</a
        >
      </li>
      <li>
        <a href="about" class="<%= currentPage === 'about' ? 'active' : '' %>"
          >About</a
        >
      </li>
      <li>
        <a
          href="reviews"
          class="<%= currentPage === 'reviews' ? 'active' : '' %>"
          >Reviews</a
        >
      </li>
      <li>
        <a href="skills" class="<%= currentPage === 'skills' ? 'active' : '' %>"
          >Skills</a
        >
      </li>
      <li>
        <a
          href="contact"
          class="<%= currentPage === 'contact' ? 'active' : '' %>"
          >Contact</a
        >
      </li>
      <li class="nav-auth">
        <a href="login" id="sign-in-btn" class="button">Login</a>
        <a href="signup" id="sign-up-btn" class="button">Sign Up</a>
        <a href="/" id="logout-btn" class="button" style="display: none"
          >Logout</a
        >
      </li>
    </ul>
  </nav>

  <!-- Mobile fullscreen overlay -->
  <nav class="navbar-overlay">
    <ul>
      <li id="training-plans-tab-mobile" style="display: none">
        <a
          href="your-training-plans"
          class="<%= currentPage === 'your-training-plans' ? 'active' : '' %>"
        >
          Your Training Plans
        </a>
      </li>
      <li>
        <a href="/" class="<%= currentPage === 'home' ? 'active' : '' %>"
          >Home</a
        >
      </li>
      <li>
        <a href="about" class="<%= currentPage === 'about' ? 'active' : '' %>"
          >About</a
        >
      </li>
      <li>
        <a
          href="reviews"
          class="<%= currentPage === 'reviews' ? 'active' : '' %>"
          >Reviews</a
        >
      </li>
      <li>
        <a href="skills" class="<%= currentPage === 'skills' ? 'active' : '' %>"
          >Skills</a
        >
      </li>
      <li>
        <a
          href="contact"
          class="<%= currentPage === 'contact' ? 'active' : '' %>"
          >Contact</a
        >
      </li>
      <li class="nav-auth">
        <a href="login" id="sign-in-btn-mobile" class="button">Login</a>
        <a href="signup" id="sign-up-btn-mobile" class="button">Sign Up</a>
        <a href="/" id="logout-btn-mobile" class="button" style="display: none"
          >Logout</a
        >
      </li>
    </ul>
  </nav>
</header>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    const menuToggle = document.querySelector(".menu-toggle");
    const navbarOverlay = document.querySelector(".navbar-overlay");

    if (menuToggle && navbarOverlay) {
      menuToggle.addEventListener("click", () => {
        navbarOverlay.classList.toggle("open");
      });

      navbarOverlay.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          navbarOverlay.classList.remove("open");
        });
      });
    }

    const trainingPlansTab = document.getElementById("training-plans-tab");
    const trainingPlansTabMobile = document.getElementById(
      "training-plans-tab-mobile"
    );

    firebase.auth().onAuthStateChanged((user) => {
      if (user) {
        if (trainingPlansTab) trainingPlansTab.style.display = "inline-block";
        if (trainingPlansTabMobile)
          trainingPlansTabMobile.style.display = "inline-block";
        // Other UI updates...
      } else {
        if (trainingPlansTab) trainingPlansTab.style.display = "none";
        if (trainingPlansTabMobile)
          trainingPlansTabMobile.style.display = "none";
        // Other UI updates...
      }
    });
  });
</script>
