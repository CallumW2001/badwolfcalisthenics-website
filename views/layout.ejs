<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title><%= title %> | Badwolf Calisthenics</title>
    <meta name="description" content="<%= description || '' %>" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="canonical"
      href="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />

    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>" />
    <meta property="og:description" content="<%= description || '' %>" />
    <meta
      property="og:image"
      content="https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png"
    />
    <meta
      property="og:url"
      content="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= title %>" />
    <meta name="twitter:description" content="<%= description || '' %>" />
    <meta
      name="twitter:image"
      content="https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png"
    />
    <meta
      name="twitter:url"
      content="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />

    <!-- Inline Critical CSS for footer and basic layout -->
    <style>
      /* Base & common layout styles */
      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
        font-family: "Orbitron", sans-serif;
        background-color: #0a0a0a;
        color: #e0e0e0;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main {
        flex-grow: 1;
        width: 100%;
        padding: 1rem;
        box-sizing: border-box;
        display: block;
      }

      /* Footer layout critical */
      footer {
        text-align: center;
        padding: 2rem;
        background-color: #111;
        color: #666;
        font-size: 0.9rem;
      }

      .footer-row {
        display: flex;
        flex-direction: row;
        justify-content: space-around;
        width: 100%;
      }

      .footer-column {
        display: flex;
        flex-direction: column;
        justify-content: center;
        width: 100%;
      }

      .footer-column:last-child {
        align-items: flex-end;
        margin-right: 50px;
      }

      /* Instagram icon link */
      .instagram-link {
        display: flex;
        animation: fadeInUp 1.8s ease-out;
        height: 48px;
        width: 48px;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        background: #fff;
        box-shadow: 0 0 6px rgba(225, 48, 108, 0.5);
        transition: background-color 0.3s ease, transform 0.3s ease;
        cursor: pointer;
      }

      .instagram-link svg {
        height: 24px;
        width: 24px;
        fill: #e1306c;
        transition: fill 0.3s ease;
      }

      .instagram-link:hover {
        background-color: #cc3b6b3a;
        box-shadow: 0 0 10px #e1306c;
        transform: scale(1.1);
      }

      .instagram-link:hover svg {
        fill: white;
      }

      @keyframes fadeInUp {
        from {
          transform: translateY(20px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }
    </style>

    <!-- Load main stylesheets asynchronously with media="print" trick -->
    <link
      rel="stylesheet"
      href="/css/styles.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="/css/layout.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="/css/styles.css" />
      <link rel="stylesheet" href="/css/layout.css" />
    </noscript>

    <!-- Firebase SDK scripts loaded asynchronously with defer -->
    <script
      src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"
      defer
    ></script>
    <script
      src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"
      defer
    ></script>

    <!-- Your Firebase config and app scripts -->
    <script src="/js/firebase-config.js" defer></script>
    <!-- JSON-LD structured data for SEO -->
    <script type="application/ld+json" defer>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Badwolf Calisthenics",
        "url": "https://www.badwolfcalisthenics.com",
        "logo": "https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png",
        "sameAs": [
          "https://www.instagram.com/badwolfcalisthenics/",
          "https://www.youtube.com/yourchannel"
        ]
      }
    </script>
  </head>
  <body>
    <!-- Shared header -->
    <%- include('partials/header') %>

    <main>
      <!-- Page-specific content -->
      <%- body %>
    </main>

    <!-- Footer -->
    <footer>
      <section class="footer-row">
        <section class="footer-column"></section>
        <section class="footer-column">
          <p>Mad Volume, The WORX, 1 Beverley Rd, Hull HU3 1XS</p>
          <p>&copy; 2025 Badwolf Calisthenics. All rights reserved.</p>
        </section>
        <section class="footer-column">
          <a
            href="https://www.instagram.com/badwolfcalisthenics/"
            target="_blank"
            rel="noopener"
            class="instagram-link"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 448 512"
              aria-hidden="true"
              role="img"
            >
              <path
                fill="#E1306C"
                d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9S160.5 370.8 224.1 370.8 339 319.5 339 255.9 287.7 141 224.1 141zm0 190.6c-41.9 0-75.9-34-75.9-75.9s34-75.9 75.9-75.9 75.9 34 75.9 75.9-34 75.9-75.9 75.9zm146.4-194.3c0 14.9-12 26.9-26.9 26.9s-26.9-12-26.9-26.9 12-26.9 26.9-26.9 26.9 12 26.9 26.9zm76.1 27.2c-1.7-35.7-9.9-67.2-36.2-93.5-26.3-26.3-57.8-34.5-93.5-36.2-37-2.1-147.9-2.1-184.9 0-35.7 1.7-67.2 9.9-93.5 36.2-26.3 26.3-34.5 57.8-36.2 93.5-2.1 37-2.1 147.9 0 184.9 1.7 35.7 9.9 67.2 36.2 93.5 26.3 26.3 57.8 34.5 93.5 36.2 37 2.1 147.9 2.1 184.9 0 35.7-1.7 67.2-9.9 93.5-36.2 26.3-26.3 34.5-57.8 36.2-93.5 2.1-37 2.1-147.8 0-184.9zm-48.1 224.5c-7.8 19.5-23 34.7-42.5 42.5-29.5 11.7-99.5 9-132.9 9s-103.4 2.6-132.9-9c-19.5-7.8-34.7-23-42.5-42.5-11.7-29.5-9-99.5-9-132.9s-2.6-103.4 9-132.9c7.8-19.5 23-34.7 42.5-42.5 29.5-11.7 99.5-9 132.9-9s103.4-2.6 132.9 9c19.5 7.8 34.7 23 42.5 42.5 11.7 29.5 9 99.5 9 132.9s2.7 103.4-9 132.9z"
              />
            </svg>
          </a>
        </section>
      </section>
    </footer>
  </body>
</html>
