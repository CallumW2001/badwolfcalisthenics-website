<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title><%= title %> | Badwolf Calisthenics</title>
    <meta name="description" content="<%= description || '' %>" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link
      rel="canonical"
      href="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />

    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %>" />
    <meta property="og:description" content="<%= description || '' %>" />
    <meta
      property="og:image"
      content="https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png"
    />
    <meta
      property="og:url"
      content="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="<%= title %>" />
    <meta name="twitter:description" content="<%= description || '' %>" />
    <meta
      name="twitter:image"
      content="https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png"
    />
    <meta
      name="twitter:url"
      content="<%= canonical || 'https://www.badwolfcalisthenics.com' %>"
    />

    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/orbitron/v20/yMJRMIlzdpvBhQQL_RqZ3yV6f0hl6Em5.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <!-- Preconnect to Google Fonts for faster font loading -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts with display=swap to avoid invisible text -->
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Inline Critical CSS (Example: minimal CSS for above-the-fold) -->
    <style>
      /* Example: Inline very minimal critical CSS to render header/nav quickly */
      body,
      html {
        margin: 0;
        padding: 0;
        font-family: "Orbitron", sans-serif;
      }
      header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem;
        background: #fff;
      }
      /* Add any other critical CSS needed for above-the-fold content */
    </style>

    <!-- Load main stylesheets asynchronously with media="print" trick -->
    <link
      rel="stylesheet"
      href="/css/styles.css"
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="stylesheet"
      href="/css/layout.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="/css/styles.css" />
      <link rel="stylesheet" href="/css/layout.css" />
    </noscript>

    <!-- Firebase SDK scripts loaded asynchronously with defer -->
    <script
      src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"
      defer
    ></script>
    <script
      src="https://www.gstatic.com/firebasejs/10.12.0/firebase-auth-compat.js"
      defer
    ></script>

    <!-- Your Firebase config and app scripts -->
    <script src="/js/firebase-config.js" defer></script>
    <!-- JSON-LD structured data for SEO -->
    <script type="application/ld+json" defer>
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Badwolf Calisthenics",
        "url": "https://www.badwolfcalisthenics.com",
        "logo": "https://www.badwolfcalisthenics.com/images/badwolf_calisthenics_logo-removebg-preview.png",
        "sameAs": [
          "https://www.instagram.com/badwolfcalisthenics/",
          "https://www.youtube.com/yourchannel"
        ]
      }
    </script>
  </head>
  <body>
    <!-- Shared header -->
    <%- include('partials/header') %>

    <main>
      <!-- Page-specific content -->
      <%- body %>
    </main>

    <!-- Footer -->
    <footer>
      <section class="footer-row">
        <section class="footer-column"></section>
        <section class="footer-column">
          <p>Mad Volume, The WORX, 1 Beverley Rd, Hull HU3 1XS</p>
          <p>&copy; 2025 Badwolf Calisthenics. All rights reserved.</p>
        </section>
        <section class="footer-column">
          <a
            href="https://www.instagram.com/badwolfcalisthenics/"
            target="_blank"
            rel="noopener"
            class="instagram-link"
            aria-label="Instagram"
          >
            <!-- Instagram SVG icon here -->
          </a>
        </section>
      </section>
    </footer>
  </body>
</html>
